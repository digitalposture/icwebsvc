{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "icwebsvc",
	"main": "src/worker.js",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
    "r2_buckets": [
    {
      "binding": "RWS",
      "bucket_name": "rws"
    }
  ]
}